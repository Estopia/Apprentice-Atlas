{
  "expo": {
    "name": "apprentice-atlas",
    "description": "A location-aware apprenticeship discovery app with maps, saved jobs, and grounded AI help.",
    "slug": "apprentice-atlas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "apprenticeatlas",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.estopiaengineering.apprenticeatlas",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Apprentice Atlas uses your location to find nearby apprenticeship opportunities.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.estopiaengineering.apprenticeatlas",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ff274d53-689a-4497-9175-023a8650e656"
      }
    },
    "owner": "estopia-engineering-ltd"
  }
}
