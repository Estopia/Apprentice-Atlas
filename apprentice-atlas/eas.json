{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "autoIncrement": true,
      "env": {
        "EXPO_USE_PRECOMPILED_MODULES": "0"
      },
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_USE_PRECOMPILED_MODULES": "0"
      }
    },
    "production": {
      "environment": "production",
      "env": {
        "EXPO_USE_PRECOMPILED_MODULES": "0"
      },
      "autoIncrement": true
    }
  }
}
