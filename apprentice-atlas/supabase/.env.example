# Server-only values for Supabase Edge Functions.
# Configure these as Supabase project secrets; never expose them as EXPO_PUBLIC_*.
# Storage is configured by the migrations: the private `user-assets` bucket does not require a separate env var.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OPENAI_API_KEY=your-openai-api-key
UK_APPRENTICESHIPS_API_URL=https://api.apprenticeships.education.gov.uk/vacancies/vacancy
UK_APPRENTICESHIPS_API_KEY=your-uk-apprenticeships-api-key
# Legacy spelling accepted temporarily for local compatibility.
UK_APRENTICESHIPS_API_KEY=your-uk-apprenticeships-api-key
UK_API_CONTRACT_CONFIRMED=false
BA_API_ENABLED=false
BA_API_URL=https://rest.arbeitsagentur.de/jobboerse/jobsuche-service/pc/v4/jobs
BA_DETAIL_API_URL=https://rest.arbeitsagentur.de/jobboerse/jobsuche-service/pc/v4/jobdetails
BA_API_KEY=your-ba-api-key
BA_FETCH_DETAILS=true
BA_DETAIL_CONCURRENCY=4
BA_SYNC_MAX_PAGES=5
