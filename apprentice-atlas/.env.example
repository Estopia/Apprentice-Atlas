# Public values are safe to expose in the Expo client.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only values: configure these in Supabase Edge Function secrets.
# Never rename these to EXPO_PUBLIC_* or commit real values.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OPENAI_API_KEY=your-openai-api-key
UK_APRENTICESHIPS_API_KEY=your-uk-apprenticeships-api-key
BA_JOBS_API_KEY=your-ba-jobs-api-key
