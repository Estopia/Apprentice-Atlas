# Public values are safe to expose in the Expo client.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Native EAS builds only. Keep this private and configure it in EAS secrets/environment variables.
GOOGLE_MAPS_API_KEY=your-google-maps-android-key

# Server-only BA ingestion values. Keep them out of the Expo client.
BA_API_ENABLED=false
BA_API_URL=https://rest.arbeitsagentur.de/jobboerse/jobsuche-service/pc/v4/jobs
BA_DETAIL_API_URL=https://rest.arbeitsagentur.de/jobboerse/jobsuche-service/pc/v4/jobdetails
BA_API_KEY=your-ba-api-key
BA_FETCH_DETAILS=true
BA_DETAIL_CONCURRENCY=4
BA_SYNC_MAX_PAGES=5
